{
  "name": "identity-service",
  "version": "1.0.0",
  "description": "Generic authentication and identity service for SaaS products",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "deploy:local": "serverless deploy --stage local",
    "deploy:dev": "serverless deploy --stage dev",
    "offline": "AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test AWS_DEFAULT_REGION=us-east-1 serverless offline start --stage local",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "localstack:init": "bash scripts/init-localstack.sh",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "identity",
    "authentication",
    "serverless",
    "aws",
    "lambda",
    "dynamodb",
    "multi-tenancy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.705.0",
    "@middy/core": "^6.4.5",
    "@middy/http-error-handler": "^6.4.5",
    "@middy/http-json-body-parser": "^6.4.5",
    "aws-lambda": "^1.0.7",
    "aws-sdk": "^2.1691.0",
    "bcryptjs": "^2.4.3",
    "dynamoose": "^4.0.1",
    "inversify": "^6.0.2",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.159",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "serverless": "^4.4.7",
    "serverless-domain-manager": "^7.4.0",
    "serverless-localstack": "^1.2.0",
    "serverless-offline": "^14.3.3",
    "serverless-offline-aws-eventbridge": "^2.2.4",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
